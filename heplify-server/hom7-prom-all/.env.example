# =============================================================================
# Homer7 Production Environment — TEMPLATE
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -- Domain -------------------------------------------------------------------
HOMER_DOMAIN=example.com

# -- PostgreSQL ---------------------------------------------------------------
POSTGRES_USER=homer
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD

# -- Grafana ------------------------------------------------------------------
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD

# -- HEP Ports (heplify-server) -----------------------------------------------
HEP_UDP_PORT=9060
HEP_TCP_PORT=9061

# -- Data Retention -----------------------------------------------------------
DB_DROP_DAYS=30
PROMETHEUS_RETENTION=30d

# -- Alerting (Slack) ---------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#homer-alerts
